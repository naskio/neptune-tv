{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neptune TV",
  "version": "0.1.0",
  "identifier": "io.nask.neptune-tv",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Neptune TV - Blazing-Fast IPTV M3U8 Player",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Mehdi Nassim KHODJA",
    "copyright": "Copyright © 2026 Mehdi Nassim KHODJA",
    "category": "Entertainment",
    "shortDescription": "Blazing-Fast IPTV M3U8 Player",
    "longDescription": "Cross-platform desktop IPTV browser. Opens large M3U8 playlists, organises channels into groups, and opens stream URLs in VLC when installed, otherwise the OS default handler.",
    "icon": [
      "icons/32x32.png",
      "icons/192x192.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
